{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "main.py"
        }
    ],
    "env": {
        "GEMINI_API_KEY": "@gemini_api_key",
        "ANKI_CONNECT_URL": "http://localhost:8765"
    }
}